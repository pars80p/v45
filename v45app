            left_align = Alignment(horizontal='left', vertical='center')
            wrap_align = Alignment(horizontal='left', vertical='top', wrap_text=True)

            def style_cell(ws, row, col, value, font=None, fill=None, align=center_align, fmt=None):
                cell = ws.cell(row=row, column=col, value=value)
                cell.border = thin_border
                if font: cell.font = font
                if fill: cell.fill = fill
                if align: cell.alignment = align
                if fmt: cell.number_format = fmt
                return cell

            def write_block_title(ws, row, title, cols=5):
                for c in range(2, 2 + cols):
                    cell = ws.cell(row=row, column=c)
                    cell.fill = block_fill
                    cell.font = block_font
                    cell.border = thin_border
                    cell.alignment = center_align
                ws.cell(row=row, column=2, value=title)

            def write_guide(ws, row_start, row_end, text):
                ws.merge_cells(start_row=row_start, start_column=6, end_row=row_end, end_column=6)
                cell = ws.cell(row=row_start, column=6, value=text)
                cell.font = guide_font
                cell.fill = guide_fill
                cell.alignment = wrap_align
                cell.border = thin_border

            # Helpers para inyectar UI stats
            p = self.parsed_data
            def safe_float(v, default):
                try: return float(v)
                except: return default

