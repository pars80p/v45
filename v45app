            self.after(0, lambda: self.finish_processing(True, f"✅ EXCEL GENERADO CON ÉXITO\n\nCélulas procesadas: {total_cells}\nTiempo: {elapsed:.1f} segundos\n\nArchivo guardado en:\n{excel_path}"))
            
        except Exception as e:
            self.after(0, lambda: self.finish_processing(False, f"❌ ERROR DURANTE LA GENERACIÓN:\n\n{str(e)}"))

    def finish_processing(self, success, msg):
        self.progress_bar.set(1.0 if success else 0.0)
        self.btn_generate.configure(state="normal", text="GENERAR EXCEL DEFINITIVO")
        
        if success:
            self.lbl_status.configure(text="Completado exitosamente.", text_color="#2ecc71")
            messagebox.showinfo("Proceso Completado", msg)
        else:
            self.lbl_status.configure(text="Error en la generación.", text_color="#e74c3c")
            messagebox.showerror("Error", msg)

if __name__ == "__main__":
    app = CDSSApp()
    app.mainloop()
