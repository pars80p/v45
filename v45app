            self.update_progress(0.4, "2. Construyendo Matriz Espacial...")
            ws1 = wb.create_sheet("Matriz Espacial")

            # Cabeceras A-L (del Groovy)
            groovy_headers = list(df.columns)

            # Cabeceras M-T (calculadas)
            calc_headers = [
                "M: Categoría IHC", "N: P Directa", "O: ISTB Lineal",
                "P: ISTB Comprimido", "Q: P Bystander", "R: P Combinada",
                "S: Destino Celular", "T: Fuente Efectiva"
            ]

            all_headers = groovy_headers + calc_headers

            for i, h in enumerate(all_headers):
                col = i + 1
                cell = ws1.cell(row=1, column=col, value=h)
                cell.font = header_font if i < len(groovy_headers) else calc_header_font
                cell.fill = dark_fill if i < len(groovy_headers) else calc_fill
                cell.border = thin_border
                cell.alignment = center_align
                ws1.column_dimensions[get_column_letter(col)].width = 18

            batch_size = max(1, total_cells // 10)

            for idx, row in df.iterrows():
                r = idx + 2
                
                # Columnas A-L: Datos crudos del Groovy
                for col_idx, val in enumerate(row.tolist()):
                    ws1.cell(row=r, column=col_idx + 1, value=val)

                # Columna M (col 13): Categoría IHC Paramétrica
                ws1.cell(row=r, column=13).value = (
                    f'=IF(B{r}="","",IF(B{r}>=\'Dashboard Clinico V45\'!$C$6,"3+",IF(B{r}>=\'Dashboard Clinico V45\'!$C$5,"2+",IF(B{r}>=\'Dashboard Clinico V45\'!$C$4,"1+",IF(B{r}>=\'Dashboard Clinico V45\'!$C$3,"0+","Negative")))))'
                )

                # Columna N (col 14): P Directa
                ws1.cell(row=r, column=14).value = (
                    f'=IF(B{r}="","",IF(M{r}="3+",\'Dashboard Clinico V45\'!$C$21,IF(M{r}="2+",\'Dashboard Clinico V45\'!$C$20,IF(M{r}="1+",\'Dashboard Clinico V45\'!$C$19,IF(M{r}="0+",\'Dashboard Clinico V45\'!$C$18,0)))))'
                )
                ws1.cell(row=r, column=14).number_format = '0.00'

                # Columna O (col 15): ISTB Lineal (Fick con DAB continuo)
                ws1.cell(row=r, column=15).value = (
                    f'=IF(B{r}="","",E{r}*EXP(-50/\'Dashboard Clinico V45\'!$C$14)+(F{r}-E{r})*EXP(-75/\'Dashboard Clinico V45\'!$C$14)+(G{r}-F{r})*EXP(-100/\'Dashboard Clinico V45\'!$C$14))'
                )
                ws1.cell(row=r, column=15).number_format = '0.0000'

                # Columna P (col 16): ISTB Comprimido
                ws1.cell(row=r, column=16).value = (
                    f'=IF(B{r}="","",LN(1+O{r})*\'Dashboard Clinico V45\'!$C$11)'
                )
                ws1.cell(row=r, column=16).number_format = '0.00'

                # Columna Q (col 17): P Bystander (Sigmoide)
                ws1.cell(row=r, column=17).value = (
                    f'=IF(B{r}="","",1/(1+EXP(-\'Dashboard Clinico V45\'!$C$13*(P{r}-\'Dashboard Clinico V45\'!$C$12))))'
                )
                ws1.cell(row=r, column=17).number_format = '0.0%'

                # Columna R (col 18): P Combinada
                ws1.cell(row=r, column=18).value = (
                    f'=IF(B{r}="","",1-((1-N{r})*(1-Q{r})))'
                )
                ws1.cell(row=r, column=18).number_format = '0.0%'

                # Columna S (col 19): Destino Celular
                ws1.cell(row=r, column=19).value = (
                    f'=IF(B{r}="","",IF(R{r}>=\'Dashboard Clinico V45\'!$C$25,"Destrucción Letal",IF(R{r}>=\'Dashboard Clinico V45\'!$C$24,"Destrucción Probable",IF(R{r}>=\'Dashboard Clinico V45\'!$C$23,"Rescate Parcial","Supervivencia"))))'
                )

                # Columna T (col 20): Fuente Efectiva (DAB propio)
                ws1.cell(row=r, column=20).value = f'=IF(B{r}="","",B{r})'
                ws1.cell(row=r, column=20).number_format = '0.0000'

                if (idx + 1) % batch_size == 0:
                    prog = 0.4 + ((idx + 1) / total_cells) * 0.5
                    self.update_progress(prog, f"Inyectando fórmulas... {idx+1}/{total_cells} células procesadas.")

            self.update_progress(0.95, "4. Guardando archivo definitivo...")
            
            save_dir = self.export_dir if self.export_dir else os.path.dirname(self.csv_path)
