    def _add_param_input(self, label_text, default_val, row, var_name):
        lbl = ctk.CTkLabel(self.sidebar_frame, text=label_text, anchor="w")
        lbl.grid(row=row*2-1, column=0, padx=20, pady=(10, 0), sticky="w")
        var = ctk.StringVar(value=default_val)
        entry = ctk.CTkEntry(self.sidebar_frame, textvariable=var)
        entry.grid(row=row*2, column=0, padx=20, pady=(0, 5), sticky="ew")
        setattr(self, var_name, var)

    def select_csv(self):
        filename = filedialog.askopenfilename(
            title="Seleccionar matriz CSV exportada por QuPath",
            filetypes=(("Archivos CSV", "*.csv"), ("Todos los archivos", "*.*"))
        )
        if filename:
            self.csv_path = filename
            self.lbl_csv_path.configure(text=filename, text_color="white")

    def select_export(self):
        folder = filedialog.askdirectory(title="Seleccionar carpeta de destino")
        if folder:
            self.export_dir = folder
            self.lbl_export_path.configure(text=folder, text_color="white")

    def parse_log(self, event=None):
        text = self.textbox_log.get("1.0", "end-1c")
        
        patterns = {
            "Células": r"Células tumorales encontradas:\s*(\d+)",
            "Calibración": r"Calibración detectada:\s*([\d.]+)",
            "Min": r"Min\s*=\s*([\d.]+)",
            "P25": r"P25\s*=\s*([\d.]+)",
            "P50": r"P50\s*=\s*([\d.]+)",
            "P75": r"P75\s*=\s*([\d.]+)",
            "P90": r"P90\s*=\s*([\d.]+)",
            "P95": r"P95\s*=\s*([\d.]+)",
            "Max": r"Max\s*=\s*([\d.]+)",
            "Mean": r"Mean\s*=\s*([\d.]+)"
        }

        parsed = {}
        for key, pattern in patterns.items():
            match = re.search(pattern, text)
            if match:
                parsed[key] = match.group(1)
        
        self.parsed_data = parsed

        if len(parsed) == 10:
            info_str = f"✅ Datos extraídos correctamente | Células: {parsed['Células']} | Calibración: {parsed['Calibración']} | Mean DAB: {parsed['Mean']}"
            self.lbl_parsed_info.configure(text=info_str, text_color="#2ecc71")
        elif len(parsed) > 0:
            info_str = f"⚠️ Datos parciales extraídos ({len(parsed)}/10)... Siga pegando o verifique el log."
            self.lbl_parsed_info.configure(text=info_str, text_color="yellow")
        else:
            self.lbl_parsed_info.configure(text="Esperando datos...", text_color="orange")

    def update_progress(self, value, text):
        self.progress_bar.set(value)
        self.lbl_status.configure(text=text)
        self.update_idletasks()

    def start_generation(self):
        if not self.csv_path:
            messagebox.showerror("Error", "Debe seleccionar el archivo CSV generado por QuPath.")
            return
        
        if len(self.parsed_data) < 10:
            ans = messagebox.askyesno("Aviso", "No se han detectado todas las estadísticas en el log. ¿Desea continuar de todos modos?\n(Las estadísticas globales quedarán en blanco en el reporte).")
            if not ans:
                return

        # Disable UI
        self.btn_generate.configure(state="disabled", text="GENERANDO...")
        threading.Thread(target=self.generate_excel, daemon=True).start()

